# Copy to `.env` and adjust as needed.
APP_NAME=Fitness Platform API
DEBUG=false

# Async SQLAlchemy URL (Phase 2+); matches docker-compose Postgres service
DATABASE_URL=postgresql+asyncpg://fitness:fitness@localhost:5433/fitness

REDIS_URL=redis://localhost:6379/0

# Strava OAuth (optional — required for Strava endpoints)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/api/v1/auth/strava/callback

# Whoop OAuth (optional — required for Whoop endpoints)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/api/v1/auth/whoop/callback

# Provider sync staleness (minutes)
SYNC_STALENESS_MINUTES=15
